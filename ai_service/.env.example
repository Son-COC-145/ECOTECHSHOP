# AI Service (FastAPI)
# Required for ai_service/main.py startup (it verifies OpenAI on boot)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# CORS (dev)
ALLOWED_ORIGINS=*

# MySQL (used by etl_pipeline.py to build data/knowledge_base.json)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=ecodb
